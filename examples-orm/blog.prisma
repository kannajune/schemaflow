// Sample Prisma schema to exercise SchemaFlow's ORM parser.

model User {
  id       Int     @id
  email    String
  posts    Post[]
}

model Post {
  id        Int      @id
  title     String
  published Boolean
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  comments  Comment[]
}

model Comment {
  id      Int    @id
  body    String
  postId  Int
  post    Post   @relation(fields: [postId], references: [id])
}
