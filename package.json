{
  "name": "schemaflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive, accessible schema visualization with diagram <-> SQL. Reads any project's SQL/migrations/ORM, distinguishes declared (fact) vs inferred (guessed) relationships.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx packages/cli/src/index.ts examples",
    "schemaflow": "tsx packages/cli/src/index.ts",
    "json": "tsx packages/cli/src/index.ts examples --json",
    "build": "npm -w schemaflow-cli run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
